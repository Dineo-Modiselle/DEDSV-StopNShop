# Copy to .env and fill in your own values (never commit .env).

MONGODB_URI=mongodb://127.0.0.1:27017/stopnshop
JWT_SECRET=change-me-to-a-long-random-string

# Optional: comma-separated browser origins (defaults include localhost:3000 and :5173)
# CORS_ORIGINS=https://your-frontend.example.com

PORT=5000
NODE_ENV=development

# Browser origin for Stripe redirects and password-reset links (Vite default: 5173)
CLIENT_URL=http://localhost:5173

STRIPE_SECRET_KEY=

BREVO_SMTP_HOST=
BREVO_SMTP_PORT=
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
EMAIL_FROM=
